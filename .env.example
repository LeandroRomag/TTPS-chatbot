# =============================================================================
# CONFIGURACIÓN DEL PROYECTO TTPS-CHATBOT
# =============================================================================
# Copia este archivo como ".env" y completa los valores necesarios.
#
# IMPORTANTE: PostgreSQL es OBLIGATORIO para este proyecto.
# Las variables DB_USER y DB_PASSWORD son requeridas.
# =============================================================================

# --- Configuración de Flask ---
SECRET_KEY=dev-secret-key-change-in-production

# --- Configuración de Base de Datos PostgreSQL (OBLIGATORIO) ---
# Estas variables son REQUERIDAS para que el proyecto funcione
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatbot_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_URL=postgresql://postgres:postgres@localhost:5432/chatbot_db

# --- WhatsApp Business API ---
WHATSAPP_TOKEN=tu_token_de_whatsapp_aqui
PHONE_NUMBER_ID=tu_phone_number_id_aqui
VERIFY_TOKEN=tu_token_de_verificacion_aqui

# Para testing (opcional)
TEST_WHATSAPP_NUMBER=5412345678XX

# --- Hugging Face API  ---
HUGGINGFACE_API_TOKEN=tu_token_de_huggingface_aqui

